---
import Base          from '../layouts/Base.astro';
import Globe         from '../components/three/Globe.svelte';
import Nav           from '../components/ui/Nav.svelte';
import ProjectCard   from '../components/ui/ProjectCard.svelte';
import SkillPill     from '../components/ui/SkillPill.svelte';
import SectionTitle  from '../components/ui/SectionTitle.svelte';
import { projects }  from '../data/projects.js';
import { skills }    from '../data/skills.js';

const featured = projects.filter(p => p.featured);
---

<Base>
  <Nav client:load />

  <!-- ═══════════════════════════════════════════════════════ HERO ══════ -->
  <section id="hero" class="hero">
    <!-- Three.js globe fills the hero -->
    <div class="globe-wrap">
      <Globe client:only="svelte" />
    </div>

    <!-- Text overlay -->
    <div class="hero-content">
      <div class="accent-line"></div>
      <h1 class="hero-name">Andrew Martin</h1>
      <p class="hero-role">GIS Designer &amp; Spatial Analyst</p>

      <!-- Hint: click a glowing marker -->
      <p class="hero-hint">Click a marker to explore projects</p>

      <!-- Scroll arrow -->
      <a href="#work" class="scroll-arrow" aria-label="Scroll to work">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M10 3v14M4 11l6 6 6-6" stroke="currentColor" stroke-width="1.5"
                stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ WORK ═══════ -->
  <section id="work" class="section">
    <div class="container">
      <SectionTitle label="Selected Work" title="Projects" client:visible />
      <div class="project-grid">
        {featured.map(p => (
          <ProjectCard
            slug={p.slug}
            title={p.title}
            subtitle={p.subtitle}
            description={p.description}
            tags={p.tags}
            gradient={p.gradient}
            year={p.year}
          />
        ))}
      </div>

      <!-- All-projects link -->
      <div class="all-projects">
        <a href="#work" class="ghost-btn">
          View all {projects.length} projects
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 7h10M7 2l5 5-5 5" stroke="currentColor" stroke-width="1.5"
                  stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ SKILLS ══════ -->
  <section id="skills" class="section skills-section">
    <div class="container">
      <SectionTitle label="Capabilities" title="Skills" client:visible />
      <div class="skills-grid">
        {skills.map(group => (
          <div class="skill-group">
            <h3 class="skill-category">{group.category}</h3>
            <div class="pills">
              {group.items.map(name => (
                <SkillPill {name} />
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ ABOUT ═══════ -->
  <section id="about" class="section about-section">
    <div class="container">
      <SectionTitle label="Background" title="About" client:visible />
      <div class="about-grid">
        <div class="about-bio">
          <p>
            I'm a GIS designer based in Seattle, WA, combining spatial analysis with
            interactive visualisation to make geographic data legible — for planners,
            scientists, and the public alike.
          </p>
          <p>
            My background spans environmental consulting, transit agencies, and independent
            research. I care about equity, precision, and the aesthetics of well-made maps.
          </p>
          <a href="mailto:andrew@example.com" class="contact-link">
            Get in touch →
          </a>
        </div>

        <div class="about-stats">
          <div class="stat">
            <span class="stat-num">6+</span>
            <span class="stat-label">Years experience</span>
          </div>
          <div class="stat">
            <span class="stat-num">40+</span>
            <span class="stat-label">Projects delivered</span>
          </div>
          <div class="stat">
            <span class="stat-num">12</span>
            <span class="stat-label">Tools mastered</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ FOOTER ══════ -->
  <footer class="footer">
    <div class="container">
      <p class="footer-copy">
        &copy; {new Date().getFullYear()} Andrew Martin
      </p>
      <ul class="footer-links">
        <li><a href="https://github.com/andrew-martin-gis" target="_blank" rel="noopener">GitHub</a></li>
        <li><a href="https://linkedin.com/in/andrew-martin-gis" target="_blank" rel="noopener">LinkedIn</a></li>
      </ul>
    </div>
  </footer>
</Base>

<style>
  /* ── Hero ───────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    height: 100svh;
    min-height: 600px;
    overflow: hidden;
  }

  .globe-wrap {
    position: absolute;
    inset: 0;
  }

  /* Ensure the Svelte Globe canvas fills its wrapper */
  .globe-wrap :global(canvas) {
    width: 100% !important;
    height: 100% !important;
    display: block;
  }

  .hero-content {
    position: absolute;
    bottom: 0;
    left: 0;
    padding: clamp(2rem, 5vw, 4.5rem);
    pointer-events: none;
  }

  .accent-line {
    width: 36px;
    height: 1px;
    background: var(--accent);
    margin-bottom: 1.4rem;
    opacity: 0;
    animation: fadeIn 0.8s ease forwards 0.4s;
  }

  .hero-name {
    /* mix-blend-mode: screen lets the globe "show through" the text */
    mix-blend-mode: screen;
    opacity: 0;
    animation: slideUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards 0.55s;
  }

  .hero-role {
    font-family: var(--font);
    font-size: clamp(0.7rem, 1.4vw, 0.95rem);
    font-weight: 300;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent-light);
    margin-top: 0.8rem;
    opacity: 0;
    animation: slideUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards 0.75s;
  }

  .hero-hint {
    font-family: var(--font);
    font-size: 0.65rem;
    font-weight: 300;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-top: 1rem;
    opacity: 0;
    animation: fadeIn 1s ease forwards 1.2s;
  }

  /* Pulsing scroll arrow */
  .scroll-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    margin-top: 2.5rem;
    color: rgba(255, 255, 255, 0.3);
    animation: arrowPulse 2.2s ease-in-out infinite 2s;
    transition: color 0.2s;
    pointer-events: auto;
  }
  .scroll-arrow:hover { color: var(--accent-light); }

  @keyframes arrowPulse {
    0%, 100% { transform: translateY(0); opacity: 0.3; }
    50%       { transform: translateY(6px); opacity: 0.8; }
  }

  /* ── Work ────────────────────────────────────────────────────────────── */
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
    gap: var(--gap);
  }

  .all-projects {
    margin-top: 3rem;
    display: flex;
    justify-content: center;
  }

  .ghost-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-secondary);
    padding: 0.65rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: color var(--transition), border-color var(--transition);
  }

  .ghost-btn:hover {
    color: var(--accent-light);
    border-color: rgba(59, 130, 246, 0.4);
  }

  /* ── Skills ──────────────────────────────────────────────────────────── */
  .skills-section {
    background: linear-gradient(to bottom, transparent, var(--bg-surface) 20%, var(--bg-surface) 80%, transparent);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 2.5rem;
  }

  .skill-category {
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent-light);
    margin-bottom: 1rem;
  }

  .pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  /* ── About ───────────────────────────────────────────────────────────── */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: start;
  }

  .about-bio {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 56ch;
  }

  .about-bio p {
    font-size: 1.05rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--text-secondary);
  }

  .contact-link {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    color: var(--accent-light);
    margin-top: 0.5rem;
    transition: letter-spacing var(--transition);
  }

  .contact-link:hover { letter-spacing: 0.18em; }

  .about-stats {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .stat { text-align: right; }

  .stat-num {
    display: block;
    font-size: 2.5rem;
    font-weight: 200;
    color: var(--text-primary);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-top: 0.3rem;
  }

  @media (max-width: 640px) {
    .about-grid { grid-template-columns: 1fr; }
    .about-stats { flex-direction: row; justify-content: space-between; }
    .stat { text-align: left; }
  }

  /* ── Footer ──────────────────────────────────────────────────────────── */
  .footer {
    padding-block: 2.5rem;
    border-top: 1px solid var(--border);
  }

  .footer .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .footer-copy {
    font-size: 0.78rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    transition: color var(--transition);
  }

  .footer-links a:hover { color: var(--accent-light); }

  /* ── Animations ──────────────────────────────────────────────────────── */
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(22px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

</style>

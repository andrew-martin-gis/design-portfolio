---
import Base          from '../layouts/Base.astro';
import Globe         from '../components/three/Globe.svelte';
import Nav           from '../components/ui/Nav.svelte';
import SectionTitle  from '../components/ui/SectionTitle.svelte';
import AppCarousel    from '../components/AppCarousel.svelte';
import AppScreenshots from '../components/AppScreenshots.svelte';
import StoreButtons   from '../components/StoreButtons.svelte';
import CountUp        from '../components/CountUp.svelte';
import { gozioApps }  from '../data/gozioApps';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const profileImg = `${base}/profile_picture.jpeg`;
---

<Base>
  <Nav client:load profileImg={profileImg} />

  <!-- ═══════════════════════════════════════════════════════ HERO ══════ -->
  <section id="hero" class="hero">
    <div class="globe-wrap">
      <Globe client:only="svelte" />
    </div>

    <div class="hero-content">
      <div class="accent-line"></div>
      <h1 class="hero-name">Andrew Martin</h1>
      <p class="hero-role">Digital Map Designer,<br/>Geospatial Developer,<br/>&amp; GIS Analyst</p>
      <a href="#work" class="scroll-arrow" aria-label="Scroll to work">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M10 3v14M4 11l6 6 6-6" stroke="currentColor" stroke-width="1.5"
                stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ GOZIO ════════ -->
  <section id="gozio" class="section gozio-section">
    <div class="container">
      <SectionTitle label="Featured Work" title="Indoor Wayfinding at Gozio" client:visible />

      <!-- Bio + Stats -->
      <div class="gozio-intro-row">
        <div class="gozio-bio">
          <img class="avatar" src={profileImg} alt="Andrew Martin" />
          <div class="bio-text">
            <p>
              I'm a digital map designer specializing in indoor wayfinding, having spent
              four years at Gozio Health creating interactive 3D maps for healthcare
              systems across the United States. What draws me to indoor mapping is the
              balance between art and science — aesthetics and spatial precision are
              equally essential to making a map that actually works for the people
              navigating it.
            </p>
            <p>
              Beyond map design, I cross-trained in QA, content management, and
              geospatial tool development, which gave me a fuller picture of the
              wayfinding lifecycle and led me to build internal automation tools that
              streamlined workflows for the whole team.
            </p>
            <a href="mailto:andrew.martin.gis@outlook.com" class="contact-link">
              Get in touch →
            </a>
          </div>
        </div>

        <div class="gozio-stats">
          <div class="stat">
            <span class="stat-number"><CountUp client:visible target={1000} suffix="+" duration={2000} /></span>
            <span class="stat-label">Indoor Maps</span>
          </div>
          <div class="stat">
            <span class="stat-number"><CountUp client:visible target={4} suffix=" yrs" duration={1800} /></span>
            <span class="stat-label">At Gozio Health</span>
          </div>
        </div>
      </div>

      <!-- Carousel (top) -->
      <AppCarousel client:visible apps={gozioApps} />

      <!-- Screenshots (middle) -->
      <div class="screenshots-row">
        <AppScreenshots client:visible apps={gozioApps} />
      </div>

      <!-- Store buttons (bottom) — reactive to active app via store -->
      <StoreButtons client:visible apps={gozioApps} />
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ ABOUT ═══════ -->
  <section id="about" class="section about-section">
    <div class="container">
      <SectionTitle label="Who I am" title="About" client:visible />
      <div class="about-asymmetric">

        <!-- Left column: Bio + Education -->
        <div class="about-left">

          <!-- Bio card -->
          <div class="about-card">
            <h3 class="about-card-heading">Bio</h3>
            <p>
              GIS professional with nearly 4 years of experience in indoor mapping,
              cartographic design, QA, data analysis, and geospatial tool development.
              Designed and maintained over 1,000 digital indoor maps for healthcare
              wayfinding. Experienced in the full mapping lifecycle — from CAD plan
              processing and 3D rendering to navigation, QA, and content management.
              Developed Python automation tools for mapping workflows and data
              analysis/monitoring.
            </p>
          </div>

          <!-- Education card -->
          <div class="about-card">
            <h3 class="about-card-heading">Education</h3>
            <div class="edu-entry">
              <span class="edu-degree">Bachelor of Science in Applied Geography, Geospatial Technologies</span>
              <span class="edu-range">Aug 2018 – Dec 2023</span>
              <span class="edu-school">University of Louisville</span>
            </div>
            <ul class="about-bullets">
              <li><strong>Thesis:</strong> Flood impact, frequency, and hydroclimatological analysis of the July 2022 Eastern Kentucky flood event — spatial analysis and hydrological modeling of Whitesburg, KY</li>
              <li><strong>Coursework:</strong> Remote Sensing, Spatial Statistics, Web GIS, Cartographic Design, Database Design, Hydrology, Python for GIS</li>
            </ul>
          </div>

        </div>

        <!-- Right column: Experience -->
        <div class="about-right">
          <div class="about-card about-card-tall">
            <h3 class="about-card-heading">Experience</h3>

            <div class="exp-entry">
              <div class="exp-header">
                <span class="exp-title">Digital Map Designer</span>
                <span class="exp-range">Jul 2022 – Mar 2026</span>
              </div>
              <span class="exp-company">Gozio Health</span>
              <ul class="about-bullets">
                <li>Designed and maintained over 1,000 digital 3D indoor maps for healthcare wayfinding across hospitals, medical offices, parking structures, and multi-building campuses using JOSM and proprietary 3D rendering software</li>
                <li>Managed the full indoor mapping production lifecycle: CAD plan conversion with precision scaling, multi-floor .osm architecture, XML theme file maintenance for 3D rendering, navigation paths, POI tagging, and web portal content management</li>
                <li>Built a multi-client BLE beacon monitoring pipeline (Python, pandas, REST API, openpyxl) automating battery health reporting across all healthcare clients replacing a manual per-client CSV process with priority-ranked Excel reports featuring voltage statistics, battery replacement projections, and missing beacon alerts</li>
                <li>Developed mapping automation and QA tools including OSM coordinate extraction, PNG calibration rotation (2D rotation matrix), POI/elevator CSV export, bulk OSM bounds extraction, and an Android ARGB-to-hex color converter</li>
                <li>Authored the company's mapper training guide: a 4-level, 50+ section knowledge base covering JOSM workflows, mapping assets, beacon placement, terminal commands, publishing workflows, and troubleshooting</li>
                <li>Led end-to-end client projects, owning all maps across all sites for multiple clients; collaborated with client success, implementation, engineering, product, and content teams</li>
                <li>Performed QA on all map deliverables, verifying navigation accuracy, 3D render integrity, and overall design consistency before client-facing deployment</li>
              </ul>
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ PROJECTS ═════ -->
  <section id="projects" class="section projects-section">
    <div class="container">
      <h2>Projects</h2>
      <!-- TODO: Projects section — planning in progress -->
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ FOOTER ══════ -->
  <footer class="footer">
    <div class="container">
      <p class="footer-copy">
        &copy; {new Date().getFullYear()} Andrew Martin
      </p>
      <ul class="footer-links">
        <li><a href="https://github.com/andrew-martin-gis" target="_blank" rel="noopener">GitHub</a></li>
        <li><a href="https://linkedin.com/in/andrew-martin-gis" target="_blank" rel="noopener">LinkedIn</a></li>
        <li><a href="mailto:andrew.martin.gis@outlook.com">Email</a></li>
      </ul>
    </div>
  </footer>
</Base>

<style>
  /* ── Hero ───────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    height: 100svh;
    min-height: 600px;
    overflow: hidden;
  }

  .globe-wrap {
    position: absolute;
    inset: 0;
  }

  .globe-wrap :global(canvas) {
    width: 100% !important;
    height: 100% !important;
    display: block;
  }

  .hero-content {
    position: absolute;
    bottom: 0;
    left: 0;
    padding: clamp(1.5rem, 4vw, 3.5rem) clamp(1.75rem, 5vw, 4.5rem);
    pointer-events: none;
    /* Stylized backdrop so text is legible over the globe in any view */
    background: linear-gradient(
      135deg,
      rgba(2, 8, 24, 0.72) 0%,
      rgba(2, 8, 24, 0.55) 70%,
      transparent 100%
    );
    border-top: 1px solid rgba(59, 130, 246, 0.12);
    border-right: 1px solid rgba(59, 130, 246, 0.08);
    border-radius: 0 1rem 0 0;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    max-width: min(480px, 60vw);
  }

  .accent-line {
    width: 36px;
    height: 1px;
    background: var(--accent);
    margin-bottom: 1.4rem;
    opacity: 0;
    animation: fadeIn 0.8s ease forwards 0.4s;
  }

  .hero-name {
    opacity: 0;
    animation: slideUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards 0.55s;
  }

  .hero-role {
    font-family: var(--font);
    font-size: clamp(0.7rem, 1.4vw, 0.95rem);
    font-weight: 300;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent-light);
    margin-top: 0.8rem;
    opacity: 0;
    animation: slideUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards 0.75s;
  }

  .scroll-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    margin-top: 2.5rem;
    color: rgba(255, 255, 255, 0.3);
    animation: arrowPulse 2.2s ease-in-out infinite 2s;
    transition: color 0.2s;
    pointer-events: auto;
  }
  .scroll-arrow:hover { color: var(--accent-light); }

  @keyframes arrowPulse {
    0%, 100% { transform: translateY(0); opacity: 0.3; }
    50%       { transform: translateY(6px); opacity: 0.8; }
  }

  /* ── About ───────────────────────────────────────────────────────────── */
  .about-section {
    padding-block: clamp(2rem, 4vw, 3.5rem);
    background: linear-gradient(to bottom, transparent, var(--bg-surface) 10%, var(--bg-surface) 90%, transparent);
  }

  .about-asymmetric {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: var(--gap);
    align-items: start;
  }

  .about-left {
    display: flex;
    flex-direction: column;
    gap: var(--gap);
  }

  .about-right {
    display: flex;
    flex-direction: column;
  }

  .about-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.75rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .about-card-tall {
    height: 100%;
  }

  .about-card-heading {
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent-light);
    margin-bottom: 0.25rem;
  }

  .about-card p {
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--text-secondary);
  }

  .contact-link {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    color: var(--accent-light);
    margin-top: 0.25rem;
    transition: letter-spacing var(--transition);
  }
  .contact-link:hover { letter-spacing: 0.18em; }

  /* Education entries */
  .edu-entry {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .edu-degree {
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--text-primary);
  }
  .edu-school {
    font-size: 0.85rem;
    font-weight: 300;
    color: var(--text-secondary);
  }
  .edu-range {
    font-size: 0.72rem;
    font-weight: 300;
    letter-spacing: 0.1em;
    color: var(--accent-light);
  }

  /* Experience entries */
  .exp-entry {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-block: 0.25rem;
  }
  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .exp-title {
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--text-primary);
  }
  .exp-range {
    font-size: 0.72rem;
    font-weight: 300;
    letter-spacing: 0.1em;
    color: var(--accent-light);
    white-space: nowrap;
  }
  .exp-company {
    font-size: 0.82rem;
    font-weight: 300;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }
  .exp-desc {
    font-size: 0.85rem;
    font-weight: 300;
    line-height: 1.65;
    color: var(--text-secondary);
    margin-top: 0.2rem;
  }
  .exp-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin-block: 0.25rem;
  }

  /* Bullet lists inside about cards */
  .about-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .about-bullets li {
    position: relative;
    padding-left: 1rem;
    font-size: 0.85rem;
    font-weight: 300;
    line-height: 1.65;
    color: var(--text-secondary);
  }
  .about-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent-light);
    opacity: 0.6;
  }
  .about-bullets strong {
    font-weight: 500;
    color: var(--text-primary);
  }

  @media (max-width: 860px) {
    .about-asymmetric {
      grid-template-columns: 1fr;
    }
  }

  /* ── Projects ────────────────────────────────────────────────────────── */
  .projects-section {
    padding-block: clamp(2rem, 4vw, 3.5rem);
  }

  /* ── Footer ──────────────────────────────────────────────────────────── */
  .footer {
    padding-block: 2.5rem;
    border-top: 1px solid var(--border);
  }

  .footer .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .footer-copy {
    font-size: 0.78rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    transition: color var(--transition);
  }

  .footer-links a:hover { color: var(--accent-light); }

  /* ── Gozio ───────────────────────────────────────────────────────────── */
  .gozio-section {
    padding-block: clamp(2rem, 4vw, 3.5rem);
    background: linear-gradient(to bottom, transparent, var(--bg-surface) 10%, var(--bg-surface) 90%, transparent);
  }

  .screenshots-row {
    margin-block: 2rem;
  }

  /* Gozio intro row: bio + stats */
  .gozio-intro-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: center;
    margin-bottom: 2rem;
  }

  .gozio-bio {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .avatar {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    object-fit: cover;
    border: 1.5px solid var(--accent);
  }

  .bio-text {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .bio-text p {
    font-size: 0.92rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--text-secondary);
  }

  .gozio-stats {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    min-width: 180px;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .stat-number {
    font-size: 2.2rem;
    font-weight: 200;
    color: var(--text-primary);
    line-height: 1.2;
  }

  .stat-label {
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }

  @media (max-width: 860px) {
    .gozio-intro-row {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .gozio-stats {
      flex-direction: row;
      justify-content: space-around;
    }
  }

  @media (max-width: 480px) {
    .gozio-bio {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }

  /* ── Animations ──────────────────────────────────────────────────────── */
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(22px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
</style>


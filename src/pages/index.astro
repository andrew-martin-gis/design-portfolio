---
import Base          from '../layouts/Base.astro';
import Globe         from '../components/three/Globe.svelte';
import Nav           from '../components/ui/Nav.svelte';
import ProjectCard   from '../components/ui/ProjectCard.svelte';
import SkillPill     from '../components/ui/SkillPill.svelte';
import SectionTitle  from '../components/ui/SectionTitle.svelte';
import AppCarousel    from '../components/AppCarousel.svelte';
import AppScreenshots from '../components/AppScreenshots.svelte';
import StoreButtons   from '../components/StoreButtons.svelte';
import { projects }   from '../data/projects.js';
import { skills }     from '../data/skills.js';
import { experience } from '../data/experience.js';
import { gozioApps }  from '../data/gozioApps';

const featured = projects.filter(p => p.featured);
---

<Base>
  <Nav client:load />

  <!-- ═══════════════════════════════════════════════════════ HERO ══════ -->
  <section id="hero" class="hero">
    <div class="globe-wrap">
      <Globe client:only="svelte" />
    </div>

    <div class="hero-content">
      <div class="accent-line"></div>
      <h1 class="hero-name">Andrew Martin</h1>
      <p class="hero-role">Digital Map Designer &amp; GIS Analyst</p>
      <a href="#work" class="scroll-arrow" aria-label="Scroll to work">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M10 3v14M4 11l6 6 6-6" stroke="currentColor" stroke-width="1.5"
                stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ WORK ═══════ -->
  <section id="work" class="section">
    <div class="container">
      <SectionTitle label="Selected Work" title="Projects" client:visible />
      <div class="project-grid">
        {featured.map((p, i) => (
          <ProjectCard
            slug={p.slug}
            title={p.title}
            subtitle={p.subtitle}
            description={p.description}
            tags={p.tags}
            gradient={p.gradient}
            year={p.year}
            type={p.type}
            index={i}
            client:visible
          />
        ))}
      </div>

      <div class="all-projects">
        <a href={`${import.meta.env.BASE_URL}projects/`} class="ghost-btn">
          View all {projects.length} projects
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 7h10M7 2l5 5-5 5" stroke="currentColor" stroke-width="1.5"
                  stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ SKILLS ══════ -->
  <section id="skills" class="section skills-section">
    <div class="container">
      <SectionTitle label="Capabilities" title="Skills" client:visible />
      <div class="skills-grid">
        {skills.map(group => (
          <div class="skill-group">
            <h3 class="skill-category">{group.category}</h3>
            <div class="pills">
              {group.items.map((item, i) => (
                <SkillPill
                  name={item.name}
                  context={item.context}
                  delay={i * 55}
                  client:visible
                />
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ GOZIO ════════ -->
  <section id="gozio" class="section gozio-section">
    <div class="container">
      <SectionTitle label="Featured Work" title="Gozio Indoor Wayfinding" client:visible />
      <p class="gozio-intro">
        At Gozio Health I've designed and shipped indoor wayfinding experiences for
        healthcare systems across the United States. These are some of the apps that
        use the maps I built.
      </p>

      <!-- Carousel (top) -->
      <AppCarousel client:visible apps={gozioApps} />

      <!-- Screenshots (middle) -->
      <div class="screenshots-row">
        <AppScreenshots client:visible apps={gozioApps} />
      </div>

      <!-- Store buttons (bottom) — reactive to active app via store -->
      <StoreButtons client:visible apps={gozioApps} />
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ EXPERIENCE ══ -->
  <section id="experience" class="section">
    <div class="container">
      <SectionTitle label="Background" title="Experience" client:visible />
      <div class="timeline">
        {experience.map((entry, idx) => (
          <div class={`timeline-entry ${idx % 2 === 0 ? 'left' : 'right'}`}>
            <div class="timeline-card">
              <span class="entry-period">{entry.period}</span>
              <h3 class="entry-role">{entry.role}</h3>
              <p class="entry-org">{entry.org}</p>
              <ul class="entry-bullets">
                {entry.bullets.map(b => <li>{b}</li>)}
              </ul>
            </div>
            <div class="timeline-node">
              <span class="node-icon">{entry.type === 'work' ? '◈' : '◇'}</span>
            </div>
            <div class="timeline-spacer"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ ABOUT ═══════ -->
  <section id="about" class="section about-section">
    <div class="container">
      <SectionTitle label="Who I am" title="About" client:visible />
      <div class="about-asymmetric">

        <!-- Left column: Bio + Education -->
        <div class="about-left">

          <!-- Bio card -->
          <div class="about-card">
            <h3 class="about-card-heading">Bio</h3>
            <!-- TODO: Replace with bio -->
            <p>
              Background in applied geography and spatial data science, currently working
              as a digital map designer building indoor wayfinding experiences for
              healthcare systems across the United States.
            </p>
            <p>
              Focused on the intersection of cartographic precision and interactive
              design — from large-scale indoor mapping pipelines to environmental GIS
              and transit equity analysis.
            </p>
            <p>
              Comfortable across the full stack of geospatial work: data modelling,
              custom rendering, and making complex spatial information legible for
              the people who depend on it every day.
            </p>
            <a href="mailto:andrew.martin.gis@outlook.com" class="contact-link">
              Get in touch →
            </a>
          </div>

          <!-- Education card -->
          <div class="about-card">
            <h3 class="about-card-heading">Education</h3>
            <!-- TODO: Replace with real education -->
            <div class="edu-entry">
              <span class="edu-degree">B.S. Geography — GIS Concentration</span>
              <span class="edu-school">University of Louisville</span>
              <span class="edu-year">2020</span>
            </div>
          </div>

        </div>

        <!-- Right column: Experience -->
        <div class="about-right">
          <div class="about-card about-card-tall">
            <h3 class="about-card-heading">Experience</h3>
            <!-- TODO: Replace with real experience -->

            <div class="exp-entry">
              <div class="exp-header">
                <span class="exp-title">Digital Map Designer</span>
                <span class="exp-range">Jan 2021 – Present</span>
              </div>
              <span class="exp-company">Gozio Health</span>
              <p class="exp-desc">
                Designed and delivered over 1,000 indoor wayfinding maps for hospital
                networks across the US, collaborating with clinical and facilities teams.
              </p>
            </div>

            <hr class="exp-divider" />

            <div class="exp-entry">
              <div class="exp-header">
                <span class="exp-title">GIS Analyst (Intern)</span>
                <span class="exp-range">May 2020 – Dec 2020</span>
              </div>
              <span class="exp-company">Placeholder Organization</span>
              <p class="exp-desc">
                Supported spatial analysis workflows and data visualisation projects
                for environmental and transit equity research initiatives.
              </p>
            </div>

            <hr class="exp-divider" />

            <div class="exp-entry">
              <div class="exp-header">
                <span class="exp-title">Research Assistant</span>
                <span class="exp-range">Aug 2019 – May 2020</span>
              </div>
              <span class="exp-company">University of Louisville</span>
              <p class="exp-desc">
                Assisted faculty with geospatial data collection, processing, and
                cartographic output for applied geography research projects.
              </p>
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ PROJECTS ═════ -->
  <section id="projects" class="section">
    <div class="container">
      <h2>Projects</h2>
      <!-- TODO: Projects section — planning in progress -->
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ FOOTER ══════ -->
  <footer class="footer">
    <div class="container">
      <p class="footer-copy">
        &copy; {new Date().getFullYear()} Andrew Martin
      </p>
      <ul class="footer-links">
        <li><a href="https://github.com/andrew-martin-gis" target="_blank" rel="noopener">GitHub</a></li>
        <li><a href="https://linkedin.com/in/andrew-martin-gis" target="_blank" rel="noopener">LinkedIn</a></li>
        <li><a href="mailto:andrew.martin.gis@outlook.com">Email</a></li>
      </ul>
    </div>
  </footer>
</Base>

<style>
  /* ── Hero ───────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    height: 100svh;
    min-height: 600px;
    overflow: hidden;
  }

  .globe-wrap {
    position: absolute;
    inset: 0;
  }

  .globe-wrap :global(canvas) {
    width: 100% !important;
    height: 100% !important;
    display: block;
  }

  .hero-content {
    position: absolute;
    bottom: 0;
    left: 0;
    padding: clamp(1.5rem, 4vw, 3.5rem) clamp(1.75rem, 5vw, 4.5rem);
    pointer-events: none;
    /* Stylized backdrop so text is legible over the globe in any view */
    background: linear-gradient(
      135deg,
      rgba(2, 8, 24, 0.72) 0%,
      rgba(2, 8, 24, 0.55) 70%,
      transparent 100%
    );
    border-top: 1px solid rgba(59, 130, 246, 0.12);
    border-right: 1px solid rgba(59, 130, 246, 0.08);
    border-radius: 0 1rem 0 0;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    max-width: min(480px, 60vw);
  }

  .accent-line {
    width: 36px;
    height: 1px;
    background: var(--accent);
    margin-bottom: 1.4rem;
    opacity: 0;
    animation: fadeIn 0.8s ease forwards 0.4s;
  }

  .hero-name {
    opacity: 0;
    animation: slideUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards 0.55s;
  }

  .hero-role {
    font-family: var(--font);
    font-size: clamp(0.7rem, 1.4vw, 0.95rem);
    font-weight: 300;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent-light);
    margin-top: 0.8rem;
    opacity: 0;
    animation: slideUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards 0.75s;
  }

  .scroll-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    margin-top: 2.5rem;
    color: rgba(255, 255, 255, 0.3);
    animation: arrowPulse 2.2s ease-in-out infinite 2s;
    transition: color 0.2s;
    pointer-events: auto;
  }
  .scroll-arrow:hover { color: var(--accent-light); }

  @keyframes arrowPulse {
    0%, 100% { transform: translateY(0); opacity: 0.3; }
    50%       { transform: translateY(6px); opacity: 0.8; }
  }

  /* ── Work ────────────────────────────────────────────────────────────── */
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
    gap: var(--gap);
  }

  .all-projects {
    margin-top: 3rem;
    display: flex;
    justify-content: center;
  }

  .ghost-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-secondary);
    padding: 0.65rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: color var(--transition), border-color var(--transition);
  }

  .ghost-btn:hover {
    color: var(--accent-light);
    border-color: rgba(59, 130, 246, 0.4);
  }

  /* ── Skills ──────────────────────────────────────────────────────────── */
  .skills-section {
    background: linear-gradient(to bottom, transparent, var(--bg-surface) 20%, var(--bg-surface) 80%, transparent);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 2.5rem;
  }

  .skill-category {
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent-light);
    margin-bottom: 1rem;
  }

  .pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  /* ── Experience ──────────────────────────────────────────────────────── */
  .timeline {
    position: relative;
  }

  /* Central spine */
  .timeline::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 1px;
    background: linear-gradient(to bottom, transparent, var(--border) 10%, var(--border) 90%, transparent);
    transform: translateX(-50%);
  }

  .timeline-entry {
    display: grid;
    grid-template-columns: 1fr 2.5rem 1fr;
    align-items: start;
    padding-bottom: 3rem;
  }

  /* Card: left entries go in col 1, right entries go in col 3 */
  .timeline-entry.left  .timeline-card    { grid-column: 1; grid-row: 1; text-align: right; }
  .timeline-entry.right .timeline-card    { grid-column: 3; grid-row: 1; }
  .timeline-entry.left  .timeline-node   { grid-column: 2; grid-row: 1; }
  .timeline-entry.right .timeline-node   { grid-column: 2; grid-row: 1; }
  .timeline-entry.left  .timeline-spacer  { grid-column: 3; grid-row: 1; }
  .timeline-entry.right .timeline-spacer  { grid-column: 1; grid-row: 1; }

  .timeline-node {
    display: flex;
    justify-content: center;
    padding-top: 1.1rem;
    z-index: 1;
  }

  .node-icon {
    font-size: 0.9rem;
    color: var(--accent);
    background: var(--bg);
    display: block;
    padding: 3px;
    line-height: 1;
  }

  .timeline-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem 1.75rem;
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .timeline-card:hover {
    border-color: var(--border-hover);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .entry-period {
    display: block;
    font-size: 0.68rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent-light);
    margin-bottom: 0.5rem;
  }

  .entry-role {
    font-size: 1.05rem;
    font-weight: 400;
    color: var(--text-primary);
    letter-spacing: 0.01em;
    margin-bottom: 0.2rem;
  }

  .entry-org {
    font-size: 0.82rem;
    font-weight: 300;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    margin-bottom: 1rem;
  }

  .entry-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .entry-bullets li {
    font-size: 0.875rem;
    font-weight: 300;
    line-height: 1.65;
    color: var(--text-secondary);
    padding-left: 1.1rem;
    position: relative;
  }

  .entry-bullets li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 0.7rem;
    top: 0.18em;
  }

  /* Right-align left-side bullets */
  .timeline-entry.left .entry-bullets li {
    padding-left: 0;
    padding-right: 1.1rem;
  }

  .timeline-entry.left .entry-bullets li::before {
    left: auto;
    right: 0;
  }

  @media (max-width: 720px) {
    .timeline::before { left: 0.75rem; }

    .timeline-entry {
      grid-template-columns: 1.5rem 1fr;
      gap: 0 1rem;
    }

    .timeline-entry.left  .timeline-card,
    .timeline-entry.right .timeline-card    { grid-column: 2; grid-row: 1; text-align: left; }
    .timeline-entry.left  .timeline-node,
    .timeline-entry.right .timeline-node   { grid-column: 1; grid-row: 1; }
    .timeline-entry.left  .timeline-spacer,
    .timeline-entry.right .timeline-spacer  { display: none; }

    .timeline-entry.left .entry-bullets li {
      padding-left: 1.1rem;
      padding-right: 0;
    }
    .timeline-entry.left .entry-bullets li::before {
      left: 0;
      right: auto;
    }
  }

  /* ── About ───────────────────────────────────────────────────────────── */
  .about-section {
    background: linear-gradient(to bottom, transparent, var(--bg-surface) 10%, var(--bg-surface) 90%, transparent);
  }

  .about-asymmetric {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: var(--gap);
    align-items: start;
  }

  .about-left {
    display: flex;
    flex-direction: column;
    gap: var(--gap);
  }

  .about-right {
    display: flex;
    flex-direction: column;
  }

  .about-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.75rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .about-card-tall {
    height: 100%;
  }

  .about-card-heading {
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent-light);
    margin-bottom: 0.25rem;
  }

  .about-card p {
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--text-secondary);
  }

  .contact-link {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    color: var(--accent-light);
    margin-top: 0.25rem;
    transition: letter-spacing var(--transition);
  }
  .contact-link:hover { letter-spacing: 0.18em; }

  /* Education entries */
  .edu-entry {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .edu-degree {
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--text-primary);
  }
  .edu-school {
    font-size: 0.85rem;
    font-weight: 300;
    color: var(--text-secondary);
  }
  .edu-year {
    font-size: 0.75rem;
    font-weight: 300;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }

  /* Experience entries */
  .exp-entry {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-block: 0.25rem;
  }
  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .exp-title {
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--text-primary);
  }
  .exp-range {
    font-size: 0.72rem;
    font-weight: 300;
    letter-spacing: 0.1em;
    color: var(--accent-light);
    white-space: nowrap;
  }
  .exp-company {
    font-size: 0.82rem;
    font-weight: 300;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }
  .exp-desc {
    font-size: 0.85rem;
    font-weight: 300;
    line-height: 1.65;
    color: var(--text-secondary);
    margin-top: 0.2rem;
  }
  .exp-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin-block: 0.25rem;
  }

  @media (max-width: 860px) {
    .about-asymmetric {
      grid-template-columns: 1fr;
    }
  }

  /* ── Footer ──────────────────────────────────────────────────────────── */
  .footer {
    padding-block: 2.5rem;
    border-top: 1px solid var(--border);
  }

  .footer .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .footer-copy {
    font-size: 0.78rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    transition: color var(--transition);
  }

  .footer-links a:hover { color: var(--accent-light); }

  /* ── Gozio ───────────────────────────────────────────────────────────── */
  .gozio-section {
    background: linear-gradient(to bottom, transparent, var(--bg-surface) 10%, var(--bg-surface) 90%, transparent);
  }

  .gozio-intro {
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--text-secondary);
    max-width: 60ch;
    margin-bottom: 3rem;
  }

  .screenshots-row {
    margin-block: 2.5rem;
  }

  /* ── Timeline scroll reveal ──────────────────────────────────────────── */
  .timeline-entry .timeline-card {
    opacity: 0;
    transition: opacity 0.65s ease, transform 0.65s ease;
  }
  .timeline-entry.left  .timeline-card { transform: translateX(-28px); }
  .timeline-entry.right .timeline-card { transform: translateX( 28px); }
  .timeline-entry.visible .timeline-card {
    opacity: 1;
    transform: none;
  }

  /* ── Animations ──────────────────────────────────────────────────────── */
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(22px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
</style>

<script>
  function initTimeline() {
    const entries = document.querySelectorAll('.timeline-entry:not(.visible)');
    if (!entries.length) return;
    const obs = new IntersectionObserver((items) => {
      items.forEach((item, i) => {
        if (item.isIntersecting) {
          setTimeout(() => item.target.classList.add('visible'), i * 120);
          obs.unobserve(item.target);
        }
      });
    }, { threshold: 0.15 });
    entries.forEach(el => obs.observe(el));
  }
  // Fires on initial load AND after every client-side page navigation
  document.addEventListener('astro:page-load', initTimeline);
</script>

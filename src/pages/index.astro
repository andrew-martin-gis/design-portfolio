---
import Base          from '../layouts/Base.astro';
import Globe         from '../components/three/Globe.svelte';
import Nav           from '../components/ui/Nav.svelte';
import SectionTitle  from '../components/ui/SectionTitle.svelte';
import AppCarousel    from '../components/AppCarousel.svelte';
import AppScreenshots from '../components/AppScreenshots.svelte';
import StoreButtons   from '../components/StoreButtons.svelte';
import CountUp        from '../components/CountUp.svelte';
import { gozioApps }  from '../data/gozioApps';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const profileImg = `${base}/profile_picture.jpeg`;
---

<Base>
  <Nav client:load profileImg={profileImg} />

  <!-- ═══════════════════════════════════════════════════════ HERO ══════ -->
  <section id="hero" class="hero">
    <div class="globe-wrap">
      <Globe client:only="svelte" />
    </div>

    <div class="hero-content">
      <div class="accent-line"></div>
      <h1 class="hero-name">Andrew Martin</h1>
      <p class="hero-role">Digital Map Designer,<br/>Geospatial Developer,<br/>&amp; GIS Analyst</p>
      <a href="#gozio" class="scroll-arrow" aria-label="Scroll to work">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M10 3v14M4 11l6 6 6-6" stroke="currentColor" stroke-width="1.5"
                stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ GOZIO ════════ -->
  <section id="gozio" class="section gozio-section">
    <div class="container">
      <SectionTitle label="Featured Work" title="Indoor Wayfinding at Gozio" client:visible />

      <!-- Bio + Stats -->
      <div class="gozio-intro-row">
        <div class="gozio-bio">
          <img class="avatar" src={profileImg} alt="Andrew Martin" />
          <div class="bio-text">
            <p>
              I'm a digital map designer specializing in indoor wayfinding, having spent
              four years at Gozio Health creating interactive 3D maps for healthcare
              systems across the United States. What draws me to indoor mapping is the
              balance between art and science — where aesthetics and spatial precision are
              equally essential to making a map that actually works for the people
              navigating it.
            </p>
            <p>
              Beyond map design, I cross-trained in QA, content management, and
              geospatial tool development, which allowed me to work on the full
              wayfinding lifecycle and led me to build internal automation tools that
              streamlined workflows for the entire team.
            </p>
            <a href="mailto:andrew.martin.gis@outlook.com" class="contact-link">
              Get in touch →
            </a>
          </div>
        </div>

        <div class="gozio-stats">
          <div class="stat">
            <span class="stat-number"><CountUp client:visible target={1000} suffix="+" duration={2000} /></span>
            <span class="stat-label">Indoor Maps</span>
          </div>
          <div class="stat">
            <span class="stat-number"><CountUp client:visible target={4} suffix=" yrs" duration={1800} /></span>
            <span class="stat-label">At Gozio Health</span>
          </div>
        </div>
      </div>

      <!-- Carousel (top) -->
      <AppCarousel client:visible apps={gozioApps} />

      <!-- Screenshots (middle) -->
      <div class="screenshots-row">
        <AppScreenshots client:visible apps={gozioApps} />
      </div>

      <!-- Store buttons (bottom) — reactive to active app via store -->
      <StoreButtons client:visible apps={gozioApps} />
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ ABOUT ═══════ -->
  <section id="about" class="section about-section">
    <div class="container">
      <SectionTitle label="More" title="About Me" client:visible />
      <div class="about-asymmetric">

        <!-- Left column: Bio + Education -->
        <div class="about-left">

          <!-- Bio card -->
          <div class="about-card">
            <h3 class="about-card-heading">Bio</h3>
            <p>
              GIS professional with nearly 4 years of experience in indoor mapping,
              cartographic design, QA, data analysis, and geospatial tool development.
              Designed and maintained over 1,000 digital indoor maps for healthcare
              wayfinding. Experienced in the full mapping lifecycle — from CAD plan
              processing and 3D rendering to navigation, QA, and content management.
              Developed Python automation tools for mapping workflows and data
              analysis/monitoring.
            </p>
          </div>

          <!-- Education card -->
          <div class="about-card">
            <h3 class="about-card-heading">Education</h3>
            <div class="edu-entry">
              <span class="edu-degree">Bachelor of Science in Applied Geography, Geospatial Technologies</span>
              <span class="edu-range">Aug 2018 – Dec 2023</span>
              <span class="edu-school">University of Louisville</span>
            </div>
            <ul class="about-bullets">
              <li><strong>Thesis:</strong> Flood impact, frequency, and hydroclimatological analysis of the July 2022 Eastern Kentucky flood event — spatial analysis and hydrological modeling of Whitesburg, KY</li>
              <li><strong>Coursework:</strong> Remote Sensing, Spatial Statistics, Web GIS, Cartographic Design, Database Design, Hydrology, Python for GIS</li>
            </ul>
          </div>

        </div>

        <!-- Right column: Experience -->
        <div class="about-right">
          <div class="about-card about-card-tall">
            <h3 class="about-card-heading">Experience</h3>

            <div class="exp-entry">
              <div class="exp-header">
                <span class="exp-title">Digital Map Designer</span>
                <span class="exp-range">Jul 2022 – Mar 2026</span>
              </div>
              <span class="exp-company">Gozio Health</span>
              <ul class="about-bullets">
                <li>Designed and maintained over 1,000 digital 3D indoor maps for healthcare wayfinding across hospitals, medical offices, parking structures, and multi-building campuses using JOSM and proprietary 3D rendering software</li>
                <li>Managed the full indoor mapping production lifecycle: CAD plan conversion with precision scaling, multi-floor .osm architecture, XML theme file maintenance for 3D rendering, navigation paths, POI tagging, and web portal content management</li>
                <li>Built a multi-client BLE beacon monitoring pipeline (Python, pandas, REST API, openpyxl) automating battery health reporting across all healthcare clients replacing a manual per-client CSV process with priority-ranked Excel reports featuring voltage statistics, battery replacement projections, and missing beacon alerts</li>
                <li>Developed mapping automation and QA tools including OSM coordinate extraction, PNG calibration rotation (2D rotation matrix), POI/elevator CSV export, bulk OSM bounds extraction, and an Android ARGB-to-hex color converter</li>
                <li>Authored the company's mapper training guide: a 4-level, 50+ section knowledge base covering JOSM workflows, mapping assets, beacon placement, terminal commands, publishing workflows, and troubleshooting</li>
                <li>Led end-to-end client projects, owning all maps across all sites for multiple clients; collaborated with client success, implementation, engineering, product, and content teams</li>
                <li>Performed QA on all map deliverables, verifying navigation accuracy, 3D render integrity, and overall design consistency before client-facing deployment</li>
              </ul>
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ SKILLS ═══════ -->
  <section id="skills" class="section skills-section">
    <div class="container">
      <SectionTitle label="What I work with" title="Technical Skills" client:visible />

      <div class="skills-groups">
        <div class="skill-group">
          <h3 class="skill-group-label">GIS &amp; Mapping</h3>
          <div class="skill-chips">
            <span class="chip">ArcGIS Pro</span>
            <span class="chip">ArcGIS Online</span>
            <span class="chip">Survey123</span>
            <span class="chip">StoryMaps</span>
            <span class="chip">JOSM</span>
            <span class="chip">Google Earth Pro</span>
            <span class="chip">Indoor Mapping &amp; Wayfinding Systems</span>
          </div>
        </div>

        <div class="skill-group">
          <h3 class="skill-group-label">Programming</h3>
          <div class="skill-chips">
            <span class="chip">Python</span>
            <span class="chip">ArcPy</span>
            <span class="chip">Shell/Bash</span>
            <span class="chip">HTML/CSS</span>
            <span class="chip">SQL</span>
            <span class="chip">JavaScript</span>
            <span class="chip">R</span>
          </div>
        </div>

        <div class="skill-group">
          <h3 class="skill-group-label">Data &amp; APIs</h3>
          <div class="skill-chips">
            <span class="chip">pandas</span>
            <span class="chip">NumPy</span>
            <span class="chip">REST APIs</span>
            <span class="chip">openpyxl</span>
            <span class="chip">JSON/GeoJSON</span>
            <span class="chip">XML</span>
            <span class="chip">File Geodatabases</span>
            <span class="chip">PostGIS</span>
            <span class="chip">Georeferencing</span>
          </div>
        </div>

        <div class="skill-group">
          <h3 class="skill-group-label">Tools</h3>
          <div class="skill-chips">
            <span class="chip">Git</span>
            <span class="chip">GitHub</span>
            <span class="chip">Bitbucket</span>
            <span class="chip">Jira</span>
            <span class="chip">Confluence</span>
            <span class="chip">VS Code</span>
            <span class="chip">Agile/Scrum</span>
          </div>
        </div>

        <div class="skill-group">
          <h3 class="skill-group-label">Design</h3>
          <div class="skill-chips">
            <span class="chip">Cartographic Design (2D &amp; 3D)</span>
            <span class="chip">Map UI/UX</span>
            <span class="chip">Data Visualization</span>
            <span class="chip">CAD Processing</span>
          </div>
        </div>

        <div class="skill-group">
          <h3 class="skill-group-label">Domain</h3>
          <div class="skill-chips">
            <span class="chip">Healthcare</span>
            <span class="chip">BLE Beacon / Indoor Positioning</span>
            <span class="chip">Wayfinding &amp; Navigation</span>
            <span class="chip">Software Development</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ PROJECTS ═════ -->
  <section id="projects" class="section projects-section">
    <div class="container">
      <SectionTitle label="More" title="Projects" client:visible />

      <div class="projects-grid">

        <!-- Development card -->
        <div class="about-card">
          <h3 class="about-card-heading">Development</h3>
          <ul class="project-links">
            <li>
              <span class="project-icon">💻</span>
              <a href="https://github.com/andrew-martin-gis/create-osm-grids" target="_blank" rel="noopener noreferrer">JOSM Grid Creation Automation Python Script</a>
            </li>
            <li>
              <span class="project-icon">💻</span>
              <a href={`${base}projects/argb-convert`}>Android ARGB to Hex Color Converter Python Script</a>
            </li>
            <li>
              <span class="project-icon">💻</span>
              <a href={`${base}projects/osm-find-coords`}>OSM Portal Bounding Box Coordinate Extractor</a>
            </li>
            <li>
              <span class="project-icon">💻</span>
              <a href={`${base}projects/osm-poi-parse`}>OSM XML Points of Interest to CSV Parser</a>
            </li>
            <li>
              <span class="project-icon">💻</span>
              <a href={`${base}projects/png-cal-rotate`}>JOSM PNG Calibration File Rotation Tool</a>
            </li>
          </ul>
        </div>

        <!-- Cartography card -->
        <div class="about-card">
          <h3 class="about-card-heading">Cartography</h3>
          <ul class="project-links">
            <li>
              <span class="project-icon">🎓</span>
              <a href={`${base}projects/whitesburg-flood-analysis`}>A Hydroclimatological Analysis of Severe Flood Events: A Case Study of Whitesburg, KY</a>
            </li>
            <li>
              <span class="project-icon">🗺️</span>
              <a href={`${base}projects/ky-poverty-inequality-webmap`}>Poverty Inequality of Kentucky Census Tracts 2020 (WebMap)</a>
            </li>
            <li>
              <span class="project-icon">🗺️</span>
              <a href={`${base}projects/clay-city-flood-map`}>Clay City Flood Map</a>
            </li>
            <li>
              <span class="project-icon">🗺️</span>
              <a href={`${base}projects/ky-coal-to-sustainable-energy`}>Shifting Kentucky Away From Coal To Sustainable Energy (StoryMap)</a>
            </li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ FOOTER ══════ -->
  <footer class="footer">
    <div class="container">
      <p class="footer-copy">
        &copy; {new Date().getFullYear()} Andrew Martin
      </p>
      <ul class="footer-links">
        <li>
          <a href="https://github.com/andrew-martin-gis" target="_blank" rel="noopener" aria-label="GitHub">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
        </li>
        <li>
          <a href="https://linkedin.com/in/andrew-martin-gis" target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </li>
        <li>
          <a href="mailto:andrew.martin.gis@outlook.com" aria-label="Email">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
          </a>
        </li>
      </ul>
    </div>
  </footer>
  <div id="bottom" aria-hidden="true"></div>
</Base>

<style>
  /* ── Hero ───────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    height: 100svh;
    min-height: 600px;
    overflow: hidden;
  }

  .globe-wrap {
    position: absolute;
    inset: 0;
  }

  .globe-wrap :global(canvas) {
    width: 100% !important;
    height: 100% !important;
    display: block;
  }

  .hero-content {
    position: absolute;
    bottom: 0;
    left: 0;
    padding: clamp(1.5rem, 4vw, 3.5rem) clamp(1.75rem, 5vw, 4.5rem);
    pointer-events: none;
    /* Stylized backdrop so text is legible over the globe in any view */
    background: linear-gradient(
      135deg,
      rgba(2, 8, 24, 0.88) 0%,
      rgba(2, 8, 24, 0.72) 60%,
      rgba(2, 8, 24, 0.35) 100%
    );
    border-top: 1px solid rgba(59, 130, 246, 0.15);
    border-right: 1px solid rgba(59, 130, 246, 0.10);
    border-radius: 0 1rem 0 0;
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    max-width: min(480px, 60vw);
  }

  .accent-line {
    width: 36px;
    height: 1px;
    background: var(--accent);
    margin-bottom: 1.4rem;
    opacity: 0;
    animation: fadeIn 0.8s ease forwards 0.4s;
  }

  .hero-name {
    opacity: 0;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.5);
    animation: slideUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards 0.55s;
  }

  .hero-role {
    font-family: var(--font);
    font-size: clamp(0.7rem, 1.4vw, 0.95rem);
    font-weight: 300;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent-light);
    margin-top: 0.8rem;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.4);
    opacity: 0;
    animation: slideUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards 0.75s;
  }

  .scroll-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    margin-top: 2.5rem;
    color: rgba(255, 255, 255, 0.3);
    animation: arrowPulse 2.2s ease-in-out infinite 2s;
    transition: color 0.2s;
    pointer-events: auto;
  }
  .scroll-arrow:hover { color: var(--accent-light); }

  @keyframes arrowPulse {
    0%, 100% { transform: translateY(0); opacity: 0.3; }
    50%       { transform: translateY(6px); opacity: 0.8; }
  }

  /* ── About ───────────────────────────────────────────────────────────── */
  .about-section {
    padding-block: clamp(2rem, 4vw, 3.5rem);
    background: linear-gradient(to bottom, transparent, var(--bg-surface) 10%, var(--bg-surface) 90%, transparent);
  }

  .about-asymmetric {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: var(--gap);
    align-items: start;
  }

  .about-left {
    display: flex;
    flex-direction: column;
    gap: var(--gap);
  }

  .about-right {
    display: flex;
    flex-direction: column;
  }

  .about-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.75rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .about-card-tall {
    height: 100%;
  }

  .about-card-heading {
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent-light);
    margin-bottom: 0.25rem;
  }

  .about-card p {
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--text-secondary);
  }

  .contact-link {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    color: var(--accent-light);
    margin-top: 0.25rem;
    transition: letter-spacing var(--transition);
  }
  .contact-link:hover { letter-spacing: 0.18em; }

  /* Education entries */
  .edu-entry {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .edu-degree {
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--text-primary);
  }
  .edu-school {
    font-size: 0.85rem;
    font-weight: 300;
    color: var(--text-secondary);
  }
  .edu-range {
    font-size: 0.72rem;
    font-weight: 300;
    letter-spacing: 0.1em;
    color: var(--accent-light);
  }

  /* Experience entries */
  .exp-entry {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-block: 0.25rem;
  }
  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .exp-title {
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--text-primary);
  }
  .exp-range {
    font-size: 0.72rem;
    font-weight: 300;
    letter-spacing: 0.1em;
    color: var(--accent-light);
    white-space: nowrap;
  }
  .exp-company {
    font-size: 0.82rem;
    font-weight: 300;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }
  .exp-desc {
    font-size: 0.85rem;
    font-weight: 300;
    line-height: 1.65;
    color: var(--text-secondary);
    margin-top: 0.2rem;
  }
  .exp-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin-block: 0.25rem;
  }

  /* Bullet lists inside about cards */
  .about-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .about-bullets li {
    position: relative;
    padding-left: 1rem;
    font-size: 0.85rem;
    font-weight: 300;
    line-height: 1.65;
    color: var(--text-secondary);
  }
  .about-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent-light);
    opacity: 0.6;
  }
  .about-bullets strong {
    font-weight: 500;
    color: var(--text-primary);
  }

  @media (max-width: 860px) {
    .about-asymmetric {
      grid-template-columns: 1fr;
    }
  }

  /* ── Skills ──────────────────────────────────────────────────────────── */
  .skills-section {
    padding-block: clamp(2rem, 4vw, 3.5rem);
  }

  .skills-groups {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .skill-group-label {
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent-light);
    margin-bottom: 0.75rem;
  }

  .skill-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .chip {
    font-size: 0.82rem;
    font-weight: 300;
    letter-spacing: 0.03em;
    color: var(--text-secondary);
    padding: 0.45rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-surface);
    white-space: nowrap;
    transition: border-color var(--transition), color var(--transition);
  }

  .chip:hover {
    border-color: var(--border-hover);
    color: var(--text-primary);
  }

  /* ── Projects ────────────────────────────────────────────────────────── */
  .projects-section {
    padding-block: clamp(2rem, 4vw, 3.5rem);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--gap);
    align-items: start;
  }

  @media (max-width: 860px) {
    .projects-grid {

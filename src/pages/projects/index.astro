---
import Base        from '../../layouts/Base.astro';
import Nav         from '../../components/ui/Nav.svelte';
import ProjectCard from '../../components/ui/ProjectCard.svelte';
import SectionTitle from '../../components/ui/SectionTitle.svelte';
import { projects } from '../../data/projects.js';

const base = import.meta.env.BASE_URL;
const profileImg = `${base}/profile_picture.jpeg`;
---

<Base
  title="Projects — Andrew Martin"
  description="All GIS and cartography projects by Andrew Martin — indoor mapping, spatial analysis, web mapping, and data visualisation."
>
  <Nav client:load profileImg={profileImg} />

  <!-- Page header -->
  <div class="page-header">
    <div class="container">
      <a href={`${base}`} class="back-link">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M12 7H2M7 12L2 7l5-5" stroke="currentColor" stroke-width="1.5"
                stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Home
      </a>
      <SectionTitle label="Portfolio" title="All Projects" client:visible />
    </div>
  </div>

  <!-- Grid of all projects -->
  <section class="section projects-section">
    <div class="container">
      <div class="project-grid">
        {projects.map((p, i) => (
          <ProjectCard
            slug={p.slug}
            title={p.title}
            subtitle={p.subtitle}
            description={p.description}
            tags={p.tags}
            gradient={p.gradient}
            year={p.year}
            type={p.type}
            index={i}
            client:visible
          />
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .page-header {
    padding-top: 8rem;
    padding-bottom: 0;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 2rem;
    transition: color var(--transition);
  }

  .back-link:hover { color: var(--accent-light); }

  .projects-section { padding-top: 2rem; }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
    gap: var(--gap);
  }
</style>

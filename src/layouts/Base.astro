---
import { ClientRouter }  from 'astro:transitions';
import Cursor            from '../components/ui/Cursor.svelte';
import ScrollProgress    from '../components/ui/ScrollProgress.svelte';
import '../styles/global.css';

interface Props {
  title?:       string;
  description?: string;
  ogImage?:     string;
}

const {
  title       = 'Andrew Martin — Digital Map Designer',
  description = 'Digital map designer and GIS analyst at Gozio Health — building indoor wayfinding maps, spatial analysis tools, and interactive visualisations.',
  ogImage,
} = Astro.props;

const base      = import.meta.env.BASE_URL;
const siteUrl   = 'https://andrew-martin-gis.github.io';
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const ogImg     = ogImage ?? `${siteUrl}${base}og.svg`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content="Andrew Martin" />
    <meta property="og:url"         content={canonical} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImg} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter / X -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImg} />

    <meta name="theme-color" content="#020818" />
    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" type="image/x-icon"  href={`${base}favicon.ico`} />

    <!-- Inter from Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400;500&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />
  </head>
  <body>
    <ScrollProgress client:only="svelte" />
    <Cursor        client:only="svelte" />
    <slot />
  </body>
</html>
